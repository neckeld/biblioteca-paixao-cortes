# --- Google OAuth 2.0 ---
# Crie em: console.cloud.google.com → Credenciais → Criar → ID do cliente OAuth 2.0
# Tipo: "Aplicativo da Web"
# URI de redirecionamento autorizado: http://localhost:3099/callback
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

